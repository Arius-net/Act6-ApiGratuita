{
  "name": "actapi",
  "version": "1.0.0",
  "description": "API REST proxy para consumir APIs de Deck of Cards y Hearthstone - Backend Express + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "vercel-build": "echo 'Vercel will handle TypeScript compilation'",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["express", "typescript", "proxy", "api", "hearthstone", "backend"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0"
  }
}
