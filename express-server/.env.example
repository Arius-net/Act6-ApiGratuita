# ==========================================
# Variables de Entorno - Express Server
# ==========================================

# Puerto del servidor (default: 4000)
PORT=4000

# Modo de ejecución (development | production)
NODE_ENV=development

# ==========================================
# Credenciales de Blizzard OAuth 2.0
# ==========================================
# Obtén estas credenciales en: https://develop.battle.net/access/clients
BLIZZARD_CLIENT_ID=tu_client_id_aqui
BLIZZARD_CLIENT_SECRET=tu_client_secret_aqui

# ==========================================
# Configuración CORS
# ==========================================
# URL del frontend permitida (separar múltiples con comas)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ==========================================
# URLs de APIs Externas (Opcional - Ya están en el código)
# ==========================================
# DECK_OF_CARDS_API=https://deckofcardsapi.com/api/deck/new/draw/?count=1
# BLIZZARD_TOKEN_URL=https://oauth.battle.net/token
# HEARTHSTONE_API_URL=https://us.api.blizzard.com/hearthstone/cards
